# Caddy serves the SPA + proxies /api/* to the FastAPI service.
# Fixed 2026-05-19: use `handle` (preserves prefix) not `handle_path` (strips it),
# and wrap the SPA branch in a `handle` block so /api/* doesn't fall through to
# file_server (which only allows GET/HEAD and was returning 405 on POST).
:80 {
    encode zstd gzip

    # API + SSE -- pass through with streaming. PREFIX PRESERVED.
    handle /api/* {
        reverse_proxy api:8000 {
            flush_interval -1   # disable buffering for SSE
            header_up Host {host}
        }
    }

    # SPA + static assets -- everything else.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    # Security headers
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ws: wss:; img-src 'self' data:; frame-ancestors 'none'"
        -Server
    }

    log {
        output stdout
        format json
    }
}
