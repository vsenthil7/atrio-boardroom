{
  "annotations": { "list": [] },
  "title": "ATRIO Overview",
  "uid": "atrio-overview",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["atrio"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API requests per minute",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api\"}[1m])) * 60",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"api\",status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active sessions",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "atrio_sessions_active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Treasury proposals (24h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "increase(atrio_treasury_proposed_total[24h])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Inference latency (p50/p95/p99)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(atrio_inference_latency_seconds_bucket[5m])) by (le, agent_id))",
          "legendFormat": "p50 {{agent_id}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(atrio_inference_latency_seconds_bucket[5m])) by (le, agent_id))",
          "legendFormat": "p95 {{agent_id}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Mandate violations (denied) — by reason",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(atrio_mandate_violations_total[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Recent error logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "loki" },
      "targets": [
        {
          "expr": "{service=\"api\"} |= \"error\" or |= \"WARNING\"",
          "refId": "A"
        }
      ]
    }
  ]
}
