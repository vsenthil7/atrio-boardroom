# ATRIO Boardroom — .env.example
# Copy to .env. Defaults below work for local mock mode (no external API keys required).

# ============================================================================
# Application
# ============================================================================
ATRIO_ENV=local                          # local | staging | demo | prod
ATRIO_BUILD_SHA=dev
ATRIO_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ============================================================================
# Database (Postgres + pgvector)
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=atrio
POSTGRES_USER=atrio
POSTGRES_PASSWORD=atrio_local_dev_password
DATABASE_URL=postgresql+asyncpg://atrio:atrio_local_dev_password@postgres:5432/atrio

# ============================================================================
# JWT (RS256). For local dev a generated keypair is fine. In prod set real keys.
# Generate: openssl genrsa -out jwt_private.pem 2048 && openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# ============================================================================
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRES_SECONDS=3600
JWT_REFRESH_EXPIRES_SECONDS=2592000

# ============================================================================
# AI Provider Keys (leave blank for mock mode)
# ============================================================================
GEMINI_API_KEY=                          # https://aistudio.google.com
FEATHERLESS_API_KEY=                     # https://featherless.ai
SPEECHMATICS_API_KEY=                    # https://portal.speechmatics.com (coupon AIWEEK200)

# In mock mode (no keys), the inference gateway returns deterministic stub
# responses so the full app works end-to-end for tests and demos.
ATRIO_MOCK_INFERENCE=true                # set to false in staging/prod

# ============================================================================
# LiveKit (voice transport)
# ============================================================================
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_at_least_32_chars_long_xxxx

# ============================================================================
# Kraken (treasury sidecar)
# ============================================================================
KRAKEN_API_KEY=                          # leave blank for paper-mock mode
KRAKEN_API_SECRET=
KRAKEN_PAPER_MODE=true                   # always true for hackathon

# ============================================================================
# Object Storage (Vultr S3-compatible). Local uses minio-compose.
# ============================================================================
S3_ENDPOINT=http://minio:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY=atrio_minio_user
S3_SECRET_KEY=atrio_minio_password
S3_BUCKET=atrio-storage
S3_FORCE_PATH_STYLE=true

# ============================================================================
# SMTP (magic-link emails). Local uses MailHog.
# ============================================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@atrio.app
SMTP_TLS=false

# ============================================================================
# CORS, security
# ============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
RATE_LIMIT_ENABLED=true

# ============================================================================
# Observability
# ============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true

# ============================================================================
# Production-only (used by docker-compose.prod.yml + Coolify)
# ============================================================================
# Container image registry (GHCR). Required for `docker compose -f
# docker/docker-compose.prod.yml` to know where to pull from. CI publishes
# to ghcr.io/<owner>/<repo>/<service>.
GITHUB_REPOSITORY=acme/atrio
ATRIO_BUILD_TAG=latest

# Grafana admin password — change before exposing grafana.atrio.app
GRAFANA_ADMIN_PASSWORD=atrio_grafana_change_me

# S3-compatible object storage (Vultr Object Storage in prod)
S3_ENDPOINT_URL=
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=atrio-prod

# ============================================================================
# Host port mapping (per claude-memory HEALTH_CHECK_RULES.md Leg 2)
# Override any of these in your local .env if the default clashes with another
# project. ATRIO defaults pinned 2026-05-19 to keep AuditEx + MendoraCI co-runnable
# (see HEALTH_CHECK_RULES.md port-registry table).
# ============================================================================
POSTGRES_HOST_PORT=5432
API_HOST_PORT=8000
FRONTEND_HOST_PORT=8080
LIVEKIT_HOST_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT=7882
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

