# ATRIO Boardroom — Production env (deploy to /srv/atrio/atrio-boardroom/.env)
#
# 02-deploy.sh copies this file to .env and runs `openssl rand` substitution
# on the __PLACEHOLDER__ tokens below. Manually-set values (API keys) need
# to be filled in BEFORE running 02-deploy.sh, or they default to "mock" mode.

# ---------- Postgres ----------
POSTGRES_DB=atrio
POSTGRES_USER=atrio
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- API ----------
API_PORT=8000
API_LOG_LEVEL=info
JWT_SECRET=__JWT_SECRET__
JWT_PRIVATE_KEY_PATH=/app/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/secrets/jwt_public.pem
JWT_ALG=RS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14
DEV_MAGIC_LINK_ECHO=false

# ---------- Frontend (Caddy SPA) ----------
FRONTEND_PORT=8080

# ---------- Inference providers ----------
# Leave blank to fall through to mock mode (demo still works).
# Fill in production keys to enable real LLM calls.
GEMINI_API_KEY=
FEATHERLESS_API_KEY=

# ---------- Speechmatics (voice mode) ----------
SPEECHMATICS_API_KEY=
SPEECHMATICS_REGION=eu

# ---------- Kraken (treasury) ----------
# Paper-mode by default. Live mode requires real API key + secret.
KRAKEN_MODE=paper
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ---------- LiveKit ----------
LIVEKIT_API_KEY=APIatrioMilan2026
LIVEKIT_API_SECRET=__LIVEKIT_API_SECRET__
LIVEKIT_KEYS=APIatrioMilan2026: __LIVEKIT_API_SECRET__
LIVEKIT_PORT=7880

# ---------- MinIO ----------
MINIO_ROOT_USER=atrio
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- Mailhog (dev only — disable for prod by stopping the service) ----------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---------- Observability ----------
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
